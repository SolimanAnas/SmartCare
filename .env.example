# DCAS CPG 2025 — environment configuration template
# Copy to ".env" and fill in real values. NEVER commit the real .env.
# (Secure SDLC §3.4 — secrets must come from the environment, not source.)

# Flask session signing key. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production. If unset, the app generates an ephemeral key and
# sessions will not survive a restart.
SECRET_KEY=

# Database connection string. Defaults to local SQLite if unset.
# Production should use an encrypted/managed database (Secure SDLC §8.4).
DATABASE_URL=sqlite:///users.db

# Google OAuth 2.0 client ID (public value). Required for Google sign-in.
GOOGLE_CLIENT_ID=

# Comma-separated allow-list of admin email addresses. Members may access the
# /api/admin/* endpoints. Users whose role is "Admin" are also treated as admins.
ADMIN_EMAILS=

# Set to "production" to enable Secure cookies + HSTS. Default: development.
APP_ENV=development

# Set to "1"/"true" only for local debugging. MUST be unset/false in production
# (Werkzeug debugger is an RCE risk). Default: off.
FLASK_DEBUG=
