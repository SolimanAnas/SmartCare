      "headers": ["Stage", "Typical Fears/Concerns", "Assessment Approach"],
      "rows": [
        ["Infant (0–12 mo)", "Separation from caregiver, hunger, discomfort", "Assess largely by observation; keep with caregiver; minimize handling"],
