{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "serviceworker": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "overrides": [
    {
      "files": ["playwright.config.js"],
      "parserOptions": {
        "sourceType": "module"
      }
    }
  ],
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "off",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-constant-condition": ["error", { "checkLoops": false }]
  }
}
